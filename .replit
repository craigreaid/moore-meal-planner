# Replit configuration — Node server with shared login + live sync.
# "Run" starts the server for previewing inside the workspace.
run = "npm start"

# Node module system for the toolchain.
modules = ["nodejs-20"]

# Map the server's internal port to the public web port.
[[ports]]
localPort = 3000
externalPort = 80

# Deploy as an always-on Reserved VM so the live (WebSocket) connection
# stays up. In the Deploy panel choose "Reserved VM" and this run command.
# Set Secrets first: FAMILY_PASSWORD and SESSION_SECRET.
[deployment]
deploymentTarget = "vm"
run = ["npm", "start"]
